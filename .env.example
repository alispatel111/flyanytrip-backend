# Server Configuration
PORT=5000

# PostgreSQL Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/flyanytrip

# Adivaha API Credentials
ADIVAHA_PID=your_adivaha_pid_here
ADIVAHA_API_KEY=your_adivaha_api_key_here

# Frontend Configuration
FRONTEND_URL=https://your-frontend-url.vercel.app
